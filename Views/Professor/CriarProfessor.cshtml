@model Professor

<form method="post" asp-action="CriarProfessor">
  <div class="form-group">
    <label for="formGroupExampleInput">Nome</label>
    <input asp-for="Nome" type="text" class="form-control" id="formGroupExampleInput" placeholder="Example input placeholder">
  </div>
  <div class="form-group">
    <label for="formGroupExampleInput2">CPF</label>
    <input asp-for="Cpf" type="text" class="form-control" id="formGroupExampleInput2" placeholder="Another input placeholder">
  </div>
  <div class="form-group">
    <label for="siape">Siape</label>
    <input asp-for="Siape" type="text" class="form-control" id="siape" />
  </div>
  <div class="form-group">
    <label for="formGroupExampleInput2">Data de Nascimento</label>
    <input asp-for="DataNascimento" type="date" class="form-control" id="formGroupExampleInput2" placeholder="Another input placeholder">
  </div>
  <div class="form-group">
    <label for="formGroupExampleInput2">Área</label>
    <select asp-for="Area" class="form-control">
        <option id="1">Computação</option>
        <option id="2">Agronomia</option>
        <option id="3">Matemática</option>
    </select>
  </div>
  <button class="mt-5 btn btn-success">Cadastrar</button>
</form>